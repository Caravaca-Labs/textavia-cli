{
  "name": "textavia",
  "version": "0.1.3",
  "description": "Fast, local-first command-line toolkit for text, data, encoding, formatting, and developer utilities.",
  "license": "MIT",
  "type": "module",
  "homepage": "https://github.com/Caravaca-Labs/textavia-cli#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Caravaca-Labs/textavia-cli.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/Caravaca-Labs/textavia-cli/issues"
  },
  "keywords": [
    "cli",
    "text-tools",
    "developer-tools",
    "agent-skills",
    "pi-package",
    "json",
    "base64",
    "csv",
    "markdown",
    "privacy"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "textavia": "./dist/cli.js",
    "txv": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": ["dist", "skills", "README.md", "LICENSE"],
  "publishConfig": {
    "access": "public"
  },
  "pi": {
    "skills": ["./skills"]
  },
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@textavia/core": "workspace:*",
    "@textavia/node-adapters": "workspace:*",
    "@textavia/plugin-standard": "workspace:*",
    "@textavia/schemas": "workspace:*",
    "commander": "^12.1.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "execa": "^9.5.2",
    "typescript": "^5.7.2"
  }
}
