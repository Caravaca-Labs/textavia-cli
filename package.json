{
  "name": "textavia-cli",
  "version": "0.1.0",
  "private": true,
  "description": "Fast, local-first command-line toolkit for text, data, encoding, formatting, and developer utilities.",
  "license": "MIT",
  "packageManager": "pnpm@10.26.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r run build",
    "test": "vitest run",
    "test:performance": "tsx scripts/performance-smoke.ts",
    "test:watch": "vitest",
    "typecheck": "pnpm -r run typecheck",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "generate:docs": "tsx scripts/generate-docs.ts && biome format --write docs/developer-tools docs/developers.json",
    "import:sitemap": "tsx scripts/import-sitemap.ts",
    "generate:skills": "tsx scripts/generate-agent-skills.ts",
    "changeset": "changeset",
    "clean": "pnpm -r exec rimraf dist *.tsbuildinfo"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@changesets/cli": "^2.27.12",
    "@types/node": "^22.10.0",
    "rimraf": "^6.0.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
