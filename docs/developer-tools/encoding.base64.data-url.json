  "category": "encoding",
  "command": "txv run encoding.base64.data-url",
  "aliases": ["data-url"],
  "examples": [
    {
      "title": "Data URL",
      "command": "txv data-url --file logo.png --mimeType image/png"
    }
  ],
  "webUrl": "https://textavia.com/tools/base64-data-url",
  "inputKind": ["text", "bytes", "file"],
  "outputKind": ["text", "bytes"],
