{
  "id": "encoding.base64.detect",
  "name": "Base64 detect",
  "summary": "Detect whether text is likely Base64.",
  "description": "Uses a conservative local heuristic to detect Base64-looking text.",
  "category": "encoding",
  "command": "txv run encoding.base64.detect",
  "aliases": ["base64 detect"],
  "examples": [
    {
      "title": "Detect Base64",
      "command": "txv base64 detect SGVsbG8= --json"
    }
  ],
  "webUrl": "https://textavia.com/tools/base64-detect",
  "inputKind": ["text"],
  "outputKind": ["json"],
  "stability": "stable",
  "requiresNetwork": false,
  "requiresFilesystem": false
}
