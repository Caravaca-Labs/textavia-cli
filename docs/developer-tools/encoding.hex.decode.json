  "command": "txv run encoding.hex.decode",
  "aliases": ["hex decode"],
  "examples": [
    {
      "title": "Hex decode",
      "command": "txv hex decode 4869",
      "output": "Hi"
    }
  ],
  "webUrl": "https://textavia.com/tools/hex-decoder",
  "inputKind": ["text", "file"],
  "outputKind": ["text", "bytes"],
