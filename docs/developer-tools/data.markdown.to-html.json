  "category": "data",
  "command": "txv run data.markdown.to-html",
  "aliases": ["markdown to-html", "markdown-to-html"],
  "examples": [
    {
      "title": "Markdown to HTML",
      "command": "txv markdown to-html README.md --out README.html"
    }
  ],
