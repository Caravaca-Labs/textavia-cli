  "summary": "Normalize a Base64 string (whitespace and padding).",
  "description": "Normalizes whitespace, URL-safe alphabet variants, and padding.",
  "category": "encoding",
  "command": "txv run encoding.base64.normalize",
  "aliases": ["base64 normalize"],
  "examples": [
    {
      "title": "Normalize Base64",
      "command": "txv base64 normalize \"SGV sbG8\"",
      "output": "SGVsbG8="
    }
  ],
  "webUrl": "https://textavia.com/tools/base64-normalize",
  "inputKind": ["text"],
  "outputKind": ["text"],
  "stability": "stable",
  "requiresNetwork": false,
  "requiresFilesystem": false
}
