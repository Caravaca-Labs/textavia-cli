  "category": "encoding",
  "command": "txv run encoding.base64.gzip-encode",
  "aliases": ["base64 gzip-encode"],
  "examples": [
    {
      "title": "Gzip encode",
      "command": "txv base64 gzip-encode \"hello\""
    }
  ],
