{
  "id": "case.upper",
  "name": "Uppercase",
  "summary": "Convert text to uppercase.",
  "description": "Convert text to uppercase. Supports stdin, positional text, and file input.",
  "category": "case",
  "command": "txv run case.upper",
  "aliases": ["upper"],
  "examples": [
    {
      "title": "Uppercase from positional text",
      "command": "txv case upper \"Hello World\"",
      "input": "Hello World",
      "output": "HELLO WORLD"
    },
    {
      "title": "Uppercase from stdin",
      "command": "echo \"Hello World\" | txv case upper"
    }
  ],
  "webUrl": "https://textavia.com/tools/case-upper",
  "docsUrl": "https://github.com/Caravaca-Labs/textavia-cli/blob/main/docs/developer-tools/case.upper.json",
  "inputKind": ["text", "file"],
  "outputKind": ["text"],
  "stability": "stable",
  "requiresNetwork": false,
  "requiresFilesystem": false
}
